# Telegram bot token from @BotFather. Required.
BOT_TOKEN=

# Powers the /ai command. Optional.
GROQ_API_KEY=

# Powers /shoti and /ishoti TikTok commands. Optional.
SHOTI_APIKEY=

# Port for the keep-alive HTTP server. Optional, defaults to 3000.
PORT=3000

# NeonDB (Postgres) connection string, from your Neon project's dashboard
# ("Connection string" — use the "Pooled connection" one). Powers users,
# groups, group members, balances, XP, and levels (see src/events/rankup.ts
# and src/lib/db.ts). Required.
# Example: postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=
